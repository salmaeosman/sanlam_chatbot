APP_NAME=bawaba-de-sanlam-ai-chatbot
APP_HOST=0.0.0.0
APP_PORT=8001
APP_DEBUG=false
SECURITY_HEADERS_ENABLED=true
AUTH_COOKIE_NAME=bawaba_access_token

GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=60
GEMINI_MAX_OUTPUT_TOKENS=1400

USER_MGMT_API_URL=http://localhost:3000
USER_MGMT_TIMEOUT_SECONDS=20
USER_MGMT_PV_UPLOAD_TIMEOUT_SECONDS=180
PV_UPLOAD_MAX_BYTES=15728640
PV_UPLOAD_ALLOWED_TYPES=application/pdf,image/jpeg,image/png,image/webp

FRONTEND_ORIGINS=http://localhost:5173
CHATBOT_DB_PATH=data/chatbot.sqlite3
RECENT_RECLAMATIONS_LIMIT=5
RECENT_NOTIFICATIONS_LIMIT=5
